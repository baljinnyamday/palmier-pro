# Clerk JWT issuer (Frontend API URL from Clerk dashboard)
CLERK_JWT_ISSUER_DOMAIN=https://your-app.clerk.accounts.dev

# Primary — required for default image, video, and TTS generation
XAI_API_KEY=
# Secondary image provider (gpt-image-2; also auto-fallback when grok image hits 5xx/timeout)
OPENAI_API_KEY=

# Optional — only needed when explicitly selecting fal-backed models (Seedance, Nano Banana Pro,
# Lyria, Sonilo, upscalers) or ElevenLabs TTS
FAL_KEY=
ELEVENLABS_API_KEY=
